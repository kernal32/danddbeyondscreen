{
  "name": "ddb-dm-screen",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "ship": "./scripts/ship-change.sh",
    "build": "npm run build --workspace=@ddb/shared-types && npm run build --workspace=@ddb/backend && npm run build --workspace=@ddb/frontend",
    "build:gentle": "bash ./scripts/build-gentle.sh",
    "dev:backend": "npm run dev --workspace=@ddb/backend",
    "dev:frontend": "npm run dev --workspace=@ddb/frontend",
    "test": "npm run test --workspace=@ddb/backend"
  },
  "engines": {
    "node": ">=20"
  }
}
