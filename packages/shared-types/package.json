{
  "name": "@ddb/shared-types",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./avatars": {
      "types": "./dist/avatars.d.ts",
      "import": "./dist/avatars.js"
    },
    "./character": {
      "types": "./dist/character.d.ts",
      "import": "./dist/character.js"
    },
    "./initiative": {
      "types": "./dist/initiative.d.ts",
      "import": "./dist/initiative.js"
    },
    "./layout": {
      "types": "./dist/layout.d.ts",
      "import": "./dist/layout.js"
    },
    "./party-card-display": {
      "types": "./dist/party-card-display.d.ts",
      "import": "./dist/party-card-display.js"
    },
    "./session": {
      "types": "./dist/session.d.ts",
      "import": "./dist/session.js"
    },
    "./theme-preferences": {
      "types": "./dist/theme-preferences.d.ts",
      "import": "./dist/theme-preferences.js"
    },
    "./themes": {
      "types": "./dist/themes.d.ts",
      "import": "./dist/themes.js"
    },
    "./widget-config": {
      "types": "./dist/widget-config.d.ts",
      "import": "./dist/widget-config.js"
    }
  },
  "scripts": {
    "build": "node ../../node_modules/typescript/lib/tsc.js -p tsconfig.json",
    "dev": "node ../../node_modules/typescript/lib/tsc.js -p tsconfig.json --watch"
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  }
}
