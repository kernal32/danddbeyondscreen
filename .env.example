# Backend (apps/backend) — copy to `.env` in repo root or pass via Docker `environment`
PORT=3001
HOST=0.0.0.0
# `true` = reflect request origin; or set explicit origin URL
CORS_ORIGIN=true

# D&D Beyond (unofficial JSON endpoint base — include trailing path segment as in reference project)
DDB_BASE_URL=https://www.dndbeyond.com/character/

# Optional: paste the browser `Cookie` header value from a logged-in /character/{id}/json request
# so the server can fetch the same JSON you see in the browser. HIGHLY SENSITIVE — never commit real values.
# DDB_COOKIE=cobaltSession=...; otherCookie=...

FETCH_TIMEOUT_MS=15000
DDB_CACHE_TTL_MS=300000
RATE_LIMIT_RPS=2
DICE_LOG_MAX=100

# Optional: user accounts (SQLite file + JWT). Secret must be at least 32 characters (e.g. openssl rand -hex 32).
# When unset or too short, /api/auth/*, /api/me, API keys, and Tampermonkey ingest (/api/ingest/party) are disabled.
# AUTH_SECRET=a624d4b32b0ea48d3db2927446496c83e4b29a827f457ca5453443596b754a20
# Local dev: default is under repo `data/`. Docker Compose sets DATABASE_PATH=/app/data/ddb-screen.db and mounts ./data → /app/data.
# DATABASE_PATH=data/ddb-screen.db

# Comma-separated emails that may call /api/admin/* (trimmed + lowercased, same as login). Empty = admin API disabled.
# ADMIN_EMAIL_ALLOWLIST=you@example.com

# Frontend build-time (apps/frontend) — empty = same origin (use reverse proxy)
# VITE_API_BASE=
# VITE_SOCKET_URL=
